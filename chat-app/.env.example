# Elektra custom MIAW chat — environment configuration
#
# These are NOT secrets. They identify your published Custom Client
# Embedded Service Deployment and are intended to be browser-visible
# (Vite bakes them into the built JS bundle). The security boundary
# is the published deployment + CORS/Trusted URLs on the Salesforce org.
#
# Copy this file to .env.local for local development, or set via
# `heroku config:set` for production.

# Salesforce Org ID (15 chars, as shown in the Code Snippet's init() call)
VITE_SF_ORG_ID=00DHo00000d5PwC

# Developer name of the Custom Client Embedded Service Deployment
VITE_SF_ES_DEVELOPER_NAME=Elektra_Custom_Chat2

# SCRT2 / messaging base URL (ends with .salesforce-scrt.com)
VITE_SF_MESSAGING_URL=https://storm-ca6e20bd4496e0.my.salesforce-scrt.com
